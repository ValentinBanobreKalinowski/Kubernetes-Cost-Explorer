POSTGRES_PASSWORD=changeme
POSTGRES_USER=app_iam_user
POSTGRES_DB=cost_explorer

# Terraform reads variables from env vars named TF_VAR_<name> (must match
# variables.tf exactly, lowercase). Mirrors the values above for `terraform
# plan/apply/destroy` to pick up without prompting.
TF_VAR_postgres_password=changeme
TF_VAR_postgres_user=postgres
TF_VAR_postgres_db=cost_explorer

# Only needed for the AWS/EKS profile - a domain you own, registered in Route53.
TF_VAR_domain_name=example.com
TF_VAR_app_hostname=cluster-metrics.example.com
